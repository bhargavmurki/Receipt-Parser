# Receipt Parser Backend Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5002

# Azure Document Intelligence (Form Recognizer) Configuration
# Get these from your Azure portal: https://portal.azure.com
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_API_KEY=your-azure-api-key-here

# Example:
# AZURE_ENDPOINT=https://receipt-parser-demo.cognitiveservices.azure.com/
# AZURE_API_KEY=1234567890abcdef1234567890abcdef