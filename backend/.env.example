# Azure Form Recognizer Configuration
AZURE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_API_KEY=your-azure-form-recognizer-api-key

# Security Configuration
JWT_SECRET=your-strong-jwt-secret-at-least-64-characters-long-for-production

# Server Configuration  
PORT=5002
NODE_ENV=development
ENABLE_DEV_LOGIN=false

# CORS Configuration
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5002
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUST_PROXY=1

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
MAX_BODY_SIZE=15728640

# Apple Sign In Configuration (optional, required for native iOS Sign in with Apple)
APPLE_AUDIENCE=com.yourcompany.receiptparser

# Production Configuration (set in production)
# NODE_ENV=production
# JWT_SECRET=your-super-strong-production-jwt-secret-at-least-64-characters
# FRONTEND_URL=https://your-frontend-domain.com
# ALLOWED_ORIGINS=https://your-frontend-domain.com
